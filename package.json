{
  "name": "worship-sync-server",
  "private": true,
  "version": "2.1.2",
  "scripts": {
    "start": "tsx server.js",
    "test": "npm run test:server",
    "test:server": "node --import tsx --test server/boardService.test.js server/authResponseSanitize.test.js server/authSessionRecovery.test.js server/inviteMembershipGuards.test.js server/churchBranding.test.js server/authDesktopBroker.test.js server/authInviteRevoke.test.js server/humanApiBearerAuth.test.js",
    "migrate:auth": "node scripts/migrate-auth.js",
    "migrate:auth:dry-run": "node scripts/migrate-auth.js --dry-run",
    "migrate:rtdb": "node scripts/migrate-rtdb.js",
    "migrate:rtdb:dry-run": "node scripts/migrate-rtdb.js --dry-run",
    "backfill:song-artists": "node scripts/backfill-song-artists.js",
    "backfill:song-artists:dry-run": "node scripts/backfill-song-artists.js --dry-run",
    "checks": "npm run test:server && npm run test --prefix client && npm run lint:check --prefix client",
    "heroku-postbuild": "cd client && npm ci && npm run build",
    "client": "cd client && npm run dev",
    "server": "npx nodemon server.js",
    "dev": "concurrently --kill-others-on-fail \"npm run server\" \"npm run client\"",
    "email:preview": "node --import tsx scripts/preview-transactional-emails.ts",
    "prepare": "husky",
    "release": "semantic-release"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@mux/mux-node": "^12.8.1",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.6",
    "@sentry/node": "^10.48.0",
    "@types/pouchdb": "^6.4.2",
    "axios": "^1.15.0",
    "body-parser": "^2.2.2",
    "cheerio": "^1.2.0",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "firebase-admin": "^13.8.0",
    "imap": "^0.8.19",
    "jade": "^1.11.0",
    "leo-profanity": "^1.9.0",
    "pouchdb": "^9.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "request": "^2.88.2",
    "resend": "^6.11.0",
    "tsx": "^4.21.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/obs-studio": "^2.17.2",
    "concurrently": "^9.2.1",
    "eruda": "^3.4.3",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.3"
  },
  "type": "module"
}
