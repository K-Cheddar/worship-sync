+const createRes = () => {
+  const res = {
+    statusCode: 200,
+    payload: null,
+    status(code) {
+      this.statusCode = code;
+      return this;
+    },
+    json(payload) {
+      this.payload = payload;
+      return this;
+    },
+    set() {
+      return this;
+    },
+    clearCookie() {
+      return this;
+    },
+  };
+  return res;
